$machine_name?="pico_tests"
$board_initialization_file?=$ORIGIN/../../boards/initialize_seeed_xiao_rp2040.resc

path add $ORIGIN/../..

log "Loading board initialization file"
include $board_initialization_file

# Set relaxed default quantum for faster simulation
# Tests that need tighter synchronization override this
emulation SetGlobalQuantum "0.0001"

include $ORIGIN/testers/load_testers.resc

log "Loading firmware file"
sysbus LoadELF $global.TEST_FILE

# Set VectorTableOffset to Flash (0x10000000) for Arduino-Pico core
sysbus.cpu0 VectorTableOffset 0x10000000
sysbus.cpu1 VectorTableOffset 0x10000000
