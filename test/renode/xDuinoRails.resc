using "test/renode/boards/seeed_xiao_rp2040.repl"

mach create
machine LoadPlatformDescription @boards/seeed_xiao_rp2040.repl

$bin?=@../../.pio/build/seeed_xiao_rp2040/firmware.elf

showAnalyzer sysbus.uart0

sysbus LoadELF $bin

macro reset
"""
    sysbus WriteDoubleWord 0x4000f000 0x1
"""

runMacro $reset
