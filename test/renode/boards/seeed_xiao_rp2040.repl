// seeed_xiao_rp2040.repl

using "platforms/cpus/rp2040.repl"

// UART0 @ 0x40034000
uart0: UART.PL011 @ sysbus 0x40034000
    -> nvic@20

// GPIO @ 0x40014000
gpio: GPIOPort.RP2040GPIO @ sysbus 0x40014000
    -> nvic@13

// User LEDs (Internal)
led_red: Miscellaneous.LED @ gpio 17
led_green: Miscellaneous.LED @ gpio 16
led_blue: Miscellaneous.LED @ gpio 25

// External LEDs for lights (D9, D10)
led_front: Miscellaneous.LED @ gpio 2
led_rear: Miscellaneous.LED @ gpio 4

gpio:
    17 -> led_red@0
    16 -> led_green@0
    25 -> led_blue@0
    2 -> led_front@0
    4 -> led_rear@0
