using "@rp2040.repl"

// Seeed Studio XIAO RP2040 Pin Mapping:
// D7: GPIO 0  (Motor A)
// D8: GPIO 1  (Motor B)
// D9: GPIO 2  (Front Light)
// D10: GPIO 4 (Rear Light)

motorA: Miscellaneous.LED @ sysbus
motorB: Miscellaneous.LED @ sysbus
lightFront: Miscellaneous.LED @ sysbus
lightRear: Miscellaneous.LED @ sysbus
