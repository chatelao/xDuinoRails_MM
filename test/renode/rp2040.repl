bootrom: Memory.MappedMemory @ sysbus 0x00000000
    size: 0x4000

flash: Memory.MappedMemory @ sysbus 0x10000000
    size: 0x200000

sram0: Memory.MappedMemory @ sysbus 0x20000000
    size: 0x40000

sram1: Memory.MappedMemory @ sysbus 0x20040000
    size: 0x2000

cpu0: CPU.CortexM @ sysbus
    cpuType: "cortex-m0+"
    cpuId: 0
    nvic: nvic

nvic: IRQControllers.NVIC @ sysbus 0xe000e000
    -> cpu0@0

uart0: UART.PL011 @ sysbus 0x40034000
    IRQ -> nvic@20

sysbus:
    init:
        // Mock RP2040 registers to satisfy bootloader/SDK
        // CLOCKS
        Tag <0x40008000 0x1000> "CLOCKS"
        // RESETS
        Tag <0x4000C000 0x1000> "RESETS"
        // PSM
        Tag <0x40010000 0x1000> "PSM"
        // IO_BANK0
        Tag <0x40014000 0x1000> "IO_BANK0"
        // PADS_BANK0
        Tag <0x4001C000 0x1000> "PADS_BANK0"
        // XOSC
        Tag <0x40024000 0x1000> "XOSC"
        Tag <0x40024004 4> "XOSC_STATUS" 0x80000000 // Stable
        // PLL_SYS
        Tag <0x40028000 0x1000> "PLL_SYS"
        Tag <0x40028000 4> "PLL_SYS_CS" 0x80000000 // Locked
        // PLL_USB
        Tag <0x4002C000 0x1000> "PLL_USB"
        Tag <0x4002C000 4> "PLL_USB_CS" 0x80000000 // Locked
        // SIO
        Tag <0xD0000000 0x1000> "SIO"
        // WATCHDOG
        Tag <0x40058000 0x1000> "WATCHDOG"
        // TIMER
        Tag <0x40054000 0x1000> "TIMER"
