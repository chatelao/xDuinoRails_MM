bootrom: Memory.MappedMemory @ sysbus 0x00000000
    size: 0x4000

flash: Memory.MappedMemory @ sysbus 0x10000000
    size: 0x200000

sram0: Memory.MappedMemory @ sysbus 0x20000000
    size: 0x40000

sram1: Memory.MappedMemory @ sysbus 0x20040000
    size: 0x2000

cpu0: CPU.CortexM @ sysbus
    cpuType: "cortex-m0+"
    id: 0
    nvic: nvic0
    performanceInMips: 125

cpu1: CPU.CortexM @ sysbus
    cpuType: "cortex-m0+"
    id: 1
    nvic: nvic1
    performanceInMips: 125
    init:
        isHalted: true

nvic0: IRQControllers.NVIC @ sysbus 0xe000e000
    -> cpu0@0

nvic1: IRQControllers.NVIC @ sysbus 0xe000e100
    -> cpu1@0

uart0: UART.RP2040Uart @ sysbus 0x40034000
    IRQ -> nvic0@20

gpio: GPIOPort.RP2040GPIO @ sysbus 0x40014000
    numberOfPins: 30
    IRQ0 -> nvic0@13
    IRQ1 -> nvic1@13

pwm: PWM.RP2040PWM @ sysbus 0x40050000
    IRQ -> nvic0@4

adc: Analog.RP2040ADC @ sysbus 0x4004c000
    IRQ -> nvic0@22

timer: Timers.RP2040Timer @ sysbus 0x40054000
    IRQ0 -> nvic0@0
    IRQ1 -> nvic0@1
    IRQ2 -> nvic0@2
    IRQ3 -> nvic0@3

watchdog: Timers.RP2040Watchdog @ sysbus 0x40058000

rtc: Timers.RP2040RTC @ sysbus 0x4005c000
    IRQ -> nvic0@25
