$name?="xiao-rp2040"
$bin?=@../../.pio/build/seeed_xiao_rp2040/firmware.elf

# Create the machine
mach create $name

# Load the core description
machine LoadPlatformDescription @cores/rp2040.repl

# Load the board description (pin mappings, LEDs)
machine LoadPlatformDescription @boards/seeed_xiao_rp2040.repl

# Tag PIO regions as ignored to avoid crashes if firmware touches them
sysbus Tag <0x50200000 0x1000> "PIO0"
sysbus Tag <0x50300000 0x1000> "PIO1"

# Set the vector table offset (required for RP2040 boot when loading ELF at flash)
cpu0 VectorTableOffset 0x10000000

# Load the firmware
sysbus LoadELF $bin

# Enable UART logging to console
showAnalyzer sysbus.uart0
