$machine_name?="xduino_decoder"
$platform_file?=$ORIGIN/boards/seeed_xiao_rp2040.repl

# Include peripheral definitions from source
include $ORIGIN/cores/initialize_peripherals_source.resc

mach create $machine_name
machine LoadPlatformDescription $platform_file

# Set up some tags for registers not fully implemented but accessed
sysbus Tag <0x40024004 4> "XOSC_STATUS" 0xFFFFFFFF
sysbus Tag <0x40028000 4> "PLL_SYS_CS" 0xFFFFFFFF
sysbus Tag <0x4002C000 4> "PLL_USB_CS" 0xFFFFFFFF

# Load firmware
sysbus LoadELF $global.ELF_FILE

# RP2040 specific: bootrom and vector table
sysbus.cpu0 VectorTableOffset 0x10000000
sysbus.cpu1 VectorTableOffset 0x10000000

# Start simulation
# cpu0 IsHalted false
